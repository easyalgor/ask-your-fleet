# ─── Confluent Cloud Flink configuration ────────────────────────────────────
# Copy this file to .env and fill in the values before running the agent.
# Never commit the real .env to source control.

# Organization & environment IDs  (found in Confluent Cloud Console → Settings)
CONFLUENT_ORG_ID=
CONFLUENT_ENV_ID=

# Compute pool ID  (Console → Flink → Compute Pools)
CONFLUENT_COMPUTE_POOL_ID=

# Flink REST API endpoint region/provider  (matches your compute pool region)
FLINK_CLOUD_REGION=us-west-2
FLINK_CLOUD_PROVIDER=aws

# Flink SQL Service Account API Key & Secret
# (Console → API Keys → Cloud resource scope)
CONFLUENT_FLINK_API_KEY=
CONFLUENT_FLINK_API_SECRET=

# Flink catalog and database (matches your Environment name and Kafka cluster)
FLINK_DEFAULT_CATALOG=kt_environment
FLINK_DEFAULT_DATABASE=fms-tableflow-demo

# ─── Confluent Cloud Kafka cluster configuration ────────────
# Used by the internal Kafka consumer to read topic data natively
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_API_KEY=
KAFKA_API_SECRET=

# ─── Confluent Schema Registry configuration ─────────────────
# Canonical variable names (preferred)
SCHEMA_REGISTRY_URL=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# Backward-compatible aliases (optional)
SR_SERVER_URL=
SR_API_KEY=
SR_API_SECRET=

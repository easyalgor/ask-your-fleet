# ─── MQTT Broker configuration (for sensor_generator.sh) ────────────────────
# Copy this file to .env.mqtt and fill in the values.

MQTT_HOST=your-broker-id.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_TOPIC=temperature
MQTT_QOS=1
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_FLAGS="--insecure -V mqttv311"

# Number of simulated sensors (default: 50)
DEVICE_COUNT=50
